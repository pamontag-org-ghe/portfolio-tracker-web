# --- Backend ---
PORT=4000
NODE_ENV=development

# JWT signing secret (generate a long random string for production!)
JWT_SECRET=change-me-in-production-please

# Data storage: "local" (JSON files under backend/.data) or "cosmos"
STORAGE_DRIVER=local

# Cosmos DB (only required when STORAGE_DRIVER=cosmos)
COSMOS_ENDPOINT=
COSMOS_KEY=
COSMOS_DATABASE=portfolio-tracker

# CORS - comma separated list of allowed origins
CORS_ORIGINS=http://localhost:5173

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:4000/api
